import { Theme } from "theme.slint";
import { Sidebar } from "widgets/sidebar.slint";
import { Dashboard } from "pages/dashboard.slint";
import { Placeholder } from "pages/placeholder.slint";
import { SourcesPage, SourceRow } from "pages/sources.slint";
import { JobsPage, JobRow } from "pages/jobs.slint";
import { SourceEditDialog } from "dialogs/source_edit.slint";
import { JobEditDialog } from "dialogs/job_edit.slint";

export { SourceRow, JobRow }

export component AppWindow inherits Window {
    title: "Backuper";
    preferred-width: 1100px;
    preferred-height: 720px;
    min-width: 900px;
    min-height: 560px;

    in-out property <int> current-page: 0;

    // ── Dashboard ────────────────────────────────────────────────
    in-out property <int> total-jobs: 0;
    in-out property <int> ok-today: 0;
    in-out property <int> failed-today: 0;
    in-out property <string> next-run: "—";

    // ── Sources ──────────────────────────────────────────────────
    in-out property <[SourceRow]> sources: [];

    // ── Jobs ─────────────────────────────────────────────────────
    in-out property <[JobRow]> jobs: [];

    // Тема
    in-out property <string> color-scheme: "system";

    // ── Source dialog ────────────────────────────────────────────
    in-out property <bool>   src-dialog-open: false;
    in-out property <string> src-dialog-name;
    in-out property <string> src-dialog-path;
    in-out property <string> src-dialog-description;
    in-out property <string> src-dialog-tags;
    in-out property <string> src-dialog-kind: "folder";

    callback add-source();
    callback edit-source(string);
    callback delete-source(string);
    callback save-source();
    callback cancel-source-dialog();
    callback browse-source-path();

    // ── Job dialog ───────────────────────────────────────────────
    in-out property <bool>   job-dialog-open: false;
    in-out property <string> job-dialog-name;
    in-out property <string> job-dialog-source;
    in-out property <bool>   job-dialog-enabled: true;
    in-out property <[string]> job-dialog-sources: [];

    callback add-job();
    callback edit-job(string);
    callback delete-job(string);
    callback save-job();
    callback cancel-job-dialog();
    callback run-job-now(string);
    callback toggle-job(string);
    callback open-logs(string);

    // ── Misc ─────────────────────────────────────────────────────
    callback navigate(int);
    callback theme-changed(string);

    HorizontalLayout {
        spacing: 0;

        Sidebar {
            selected: root.current-page;
            select-page(p) => {
                root.current-page = p;
                root.navigate(p);
            }
        }

        Rectangle {
            background: Theme.bg;
            horizontal-stretch: 1;

            if root.current-page == 0 : Dashboard {
                total-jobs: root.total-jobs;
                ok-today: root.ok-today;
                failed-today: root.failed-today;
                next-run: root.next-run;
            }
            if root.current-page == 1 : JobsPage {
                jobs: root.jobs;
                add-job        => { root.add-job(); }
                run-job-now(id)=> { root.run-job-now(id); }
                edit-job(id)   => { root.edit-job(id); }
                delete-job(id) => { root.delete-job(id); }
            }
            if root.current-page == 2 : SourcesPage {
                sources: root.sources;
                add-source     => { root.add-source(); }
                edit-source(id)=> { root.edit-source(id); }
                delete-source(id) => { root.delete-source(id); }
            }
            if root.current-page == 3 : Placeholder {
                title: "Хранилища";
                hint: "Локальный диск + UNC сейчас, облака — Stage 4.";
            }
            if root.current-page == 4 : Placeholder {
                title: "Журнал";
                hint: "Просмотр логов с фильтрами — Stage 2.";
            }
            if root.current-page == 5 : Placeholder {
                title: "Настройки";
                hint: "Темы, автозапуск, язык, обновления — Stage 6.";
            }
        }
    }

    SourceEditDialog {
        open <=> root.src-dialog-open;
        name-value <=> root.src-dialog-name;
        path-value <=> root.src-dialog-path;
        description-value <=> root.src-dialog-description;
        tags-value <=> root.src-dialog-tags;
        kind-value <=> root.src-dialog-kind;
        save   => { root.save-source(); }
        cancel => { root.cancel-source-dialog(); }
        browse-path => { root.browse-source-path(); }
    }

    JobEditDialog {
        open <=> root.job-dialog-open;
        name-value <=> root.job-dialog-name;
        source-value <=> root.job-dialog-source;
        enabled-value <=> root.job-dialog-enabled;
        source-options: root.job-dialog-sources;
        save   => { root.save-job(); }
        cancel => { root.cancel-job-dialog(); }
    }
}
