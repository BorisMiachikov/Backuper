import { Theme } from "theme.slint";
import { Sidebar } from "widgets/sidebar.slint";
import { Dashboard, RunRow } from "pages/dashboard.slint";
import { SourcesPage, SourceRow } from "pages/sources.slint";
import { JobsPage, JobRow } from "pages/jobs.slint";
import { StoragesPage, StorageRow } from "pages/storages.slint";
import { JournalPage, JournalRow } from "pages/journal.slint";
import { SettingsPage } from "pages/settings.slint";
import { SourceEditDialog } from "dialogs/source_edit.slint";
import { JobEditDialog } from "dialogs/job_edit.slint";
import { ScheduleEditDialog } from "dialogs/schedule_edit.slint";
import { StorageEditDialog } from "dialogs/storage_edit.slint";

export { SourceRow, JobRow, RunRow, StorageRow, JournalRow }

export component AppWindow inherits Window {
    title: "Backuper";
    preferred-width: 1100px;
    preferred-height: 720px;
    min-width: 900px;
    min-height: 560px;

    in-out property <int> current-page: 0;

    // ── Dashboard ────────────────────────────────────────────────
    in-out property <int> total-jobs: 0;
    in-out property <int> ok-today: 0;
    in-out property <int> failed-today: 0;
    in-out property <string> next-run: "—";
    in-out property <[RunRow]> recent-runs: [];

    // ── Sources ──────────────────────────────────────────────────
    in-out property <[SourceRow]> sources: [];

    // ── Jobs ─────────────────────────────────────────────────────
    in-out property <[JobRow]> jobs: [];

    // ── Storages ─────────────────────────────────────────────────
    in-out property <[StorageRow]> storages-list: [];

    // ── Journal ──────────────────────────────────────────────────
    in-out property <[JournalRow]> journal-runs: [];

    // Тема
    in-out property <string> color-scheme: "system";

    // ── Source dialog ────────────────────────────────────────────
    in-out property <bool>   src-dialog-open: false;
    in-out property <string> src-dialog-name;
    in-out property <string> src-dialog-path;
    in-out property <string> src-dialog-description;
    in-out property <string> src-dialog-tags;
    in-out property <string> src-dialog-kind: "folder";
    in-out property <string> src-dialog-id: "";    // "" = add, uuid = edit

    callback add-source();
    callback edit-source(string);
    callback delete-source(string);
    callback save-source();
    callback cancel-source-dialog();
    callback browse-source-path();

    // ── Job dialog ───────────────────────────────────────────────
    in-out property <bool>   job-dialog-open: false;
    in-out property <string> job-dialog-name;
    in-out property <string> job-dialog-source;
    in-out property <bool>   job-dialog-enabled: true;
    in-out property <[string]> job-dialog-sources: [];
    in-out property <[string]> job-dialog-storages: [];
    in-out property <string> job-dialog-storage: "";
    in-out property <string> job-dialog-id: "";    // "" = add, uuid = edit
    in-out property <int>    job-dialog-keep-last: 14;
    in-out property <int>    job-dialog-max-age-days: 0;

    callback add-job();
    callback edit-job(string);
    callback delete-job(string);
    callback save-job();
    callback cancel-job-dialog();
    callback run-job-now(string);
    callback toggle-job(string);
    callback open-schedule(string);
    callback save-schedule();
    callback cancel-schedule-dialog();
    callback open-logs(string);

    // ── Schedule dialog ──────────────────────────────────────────
    in-out property <bool>   sched-dialog-open: false;
    in-out property <string> sched-dialog-job-id: "";
    in-out property <string> sched-dialog-job-name: "";
    in-out property <string> sched-dialog-kind: "none";
    in-out property <int>    sched-dialog-every-minutes: 60;
    in-out property <int>    sched-dialog-daily-hour: 2;
    in-out property <int>    sched-dialog-daily-minute: 0;
    in-out property <int>    sched-dialog-weekly-weekday: 1;
    in-out property <int>    sched-dialog-weekly-hour: 2;
    in-out property <int>    sched-dialog-weekly-minute: 0;
    in-out property <string> sched-dialog-cron-expr: "0 2 * * *";

    // ── Storage dialog ───────────────────────────────────────────
    in-out property <bool>   stor-dialog-open: false;
    in-out property <string> stor-dialog-id: "";
    in-out property <string> stor-dialog-name;
    in-out property <string> stor-dialog-kind: "local";
    in-out property <string> stor-dialog-path;
    in-out property <bool>   stor-dialog-enabled: true;

    callback add-storage();
    callback edit-storage(string);
    callback delete-storage(string);
    callback save-storage();
    callback cancel-storage-dialog();
    callback browse-storage-path();

    // ── Settings ─────────────────────────────────────────────────
    in-out property <string> settings-theme: "system";
    in-out property <int>    settings-max-parallel: 2;
    in-out property <bool>   settings-autostart: false;
    callback save-settings();

    // ── Misc ─────────────────────────────────────────────────────
    callback navigate(int);
    callback theme-changed(string);

    HorizontalLayout {
        spacing: 0;

        Sidebar {
            selected: root.current-page;
            select-page(p) => {
                root.current-page = p;
                root.navigate(p);
            }
        }

        Rectangle {
            background: Theme.bg;
            horizontal-stretch: 1;

            if root.current-page == 0 : Dashboard {
                total-jobs: root.total-jobs;
                ok-today: root.ok-today;
                failed-today: root.failed-today;
                next-run: root.next-run;
                recent-runs: root.recent-runs;
            }
            if root.current-page == 1 : JobsPage {
                jobs: root.jobs;
                add-job            => { root.add-job(); }
                run-job-now(id)    => { root.run-job-now(id); }
                edit-job(id)       => { root.edit-job(id); }
                toggle-job(id)     => { root.toggle-job(id); }
                open-schedule(id)  => { root.open-schedule(id); }
                delete-job(id)     => { root.delete-job(id); }
            }
            if root.current-page == 2 : SourcesPage {
                sources: root.sources;
                add-source     => { root.add-source(); }
                edit-source(id)=> { root.edit-source(id); }
                delete-source(id) => { root.delete-source(id); }
            }
            if root.current-page == 3 : StoragesPage {
                storages: root.storages-list;
                add-storage      => { root.add-storage(); }
                edit-storage(id) => { root.edit-storage(id); }
                delete-storage(id) => { root.delete-storage(id); }
            }
            if root.current-page == 4 : JournalPage {
                runs: root.journal-runs;
            }
            if root.current-page == 5 : SettingsPage {
                theme-value      <=> root.settings-theme;
                max-parallel     <=> root.settings-max-parallel;
                autostart-value  <=> root.settings-autostart;
                save-settings    => { root.save-settings(); }
            }
        }
    }

    SourceEditDialog {
        open <=> root.src-dialog-open;
        dialog-id <=> root.src-dialog-id;
        name-value <=> root.src-dialog-name;
        path-value <=> root.src-dialog-path;
        description-value <=> root.src-dialog-description;
        tags-value <=> root.src-dialog-tags;
        kind-value <=> root.src-dialog-kind;
        save   => { root.save-source(); }
        cancel => { root.cancel-source-dialog(); }
        browse-path => { root.browse-source-path(); }
    }

    JobEditDialog {
        open <=> root.job-dialog-open;
        dialog-id <=> root.job-dialog-id;
        name-value <=> root.job-dialog-name;
        source-value <=> root.job-dialog-source;
        enabled-value <=> root.job-dialog-enabled;
        source-options: root.job-dialog-sources;
        storage-options: root.job-dialog-storages;
        storage-value <=> root.job-dialog-storage;
        keep-last-value <=> root.job-dialog-keep-last;
        max-age-days-value <=> root.job-dialog-max-age-days;
        save   => { root.save-job(); }
        cancel => { root.cancel-job-dialog(); }
    }

    ScheduleEditDialog {
        open               <=> root.sched-dialog-open;
        job-name           <=> root.sched-dialog-job-name;
        kind-value         <=> root.sched-dialog-kind;
        every-minutes      <=> root.sched-dialog-every-minutes;
        daily-hour         <=> root.sched-dialog-daily-hour;
        daily-minute       <=> root.sched-dialog-daily-minute;
        weekly-weekday     <=> root.sched-dialog-weekly-weekday;
        weekly-hour        <=> root.sched-dialog-weekly-hour;
        weekly-minute      <=> root.sched-dialog-weekly-minute;
        cron-expr          <=> root.sched-dialog-cron-expr;
        save   => { root.save-schedule(); }
        cancel => { root.cancel-schedule-dialog(); }
    }

    StorageEditDialog {
        open            <=> root.stor-dialog-open;
        dialog-id       <=> root.stor-dialog-id;
        name-value      <=> root.stor-dialog-name;
        kind-value      <=> root.stor-dialog-kind;
        path-value      <=> root.stor-dialog-path;
        enabled-value   <=> root.stor-dialog-enabled;
        save        => { root.save-storage(); }
        cancel      => { root.cancel-storage-dialog(); }
        browse-path => { root.browse-storage-path(); }
    }
}
