import { ScrollView } from "std-widgets.slint";
import { Theme } from "../theme.slint";
import { PrimaryButton, GhostButton } from "../widgets/button.slint";

export struct StorageRow {
    id: string,
    name: string,
    kind: string,
    path: string,
    enabled: bool,
}

component StorageCard inherits Rectangle {
    in property <StorageRow> data;
    callback edit;
    callback remove;

    background: Theme.bg-elevated;
    border-radius: Theme.radius-md;
    border-width: 1px;
    border-color: Theme.border;
    height: 80px;

    HorizontalLayout {
        padding: Theme.spacing-lg;
        spacing: Theme.spacing-lg;
        alignment: stretch;

        VerticalLayout {
            horizontal-stretch: 1;
            spacing: 4px;
            alignment: center;

            HorizontalLayout {
                spacing: Theme.spacing-sm;
                Text {
                    text: data.name;
                    font-size: 15px;
                    font-weight: 600;
                    color: Theme.fg;
                }
                Rectangle {
                    background: Theme.accent.with-alpha(0.15);
                    border-radius: 4px;
                    height: 18px;
                    HorizontalLayout {
                        padding-left: 6px;
                        padding-right: 6px;
                        Text {
                            text: data.kind;
                            font-size: 11px;
                            color: Theme.accent;
                            vertical-alignment: center;
                        }
                    }
                }
                if !data.enabled : Rectangle {
                    background: Theme.fg-muted.with-alpha(0.15);
                    border-radius: 4px;
                    height: 18px;
                    HorizontalLayout {
                        padding-left: 6px;
                        padding-right: 6px;
                        Text {
                            text: "выключен";
                            font-size: 11px;
                            color: Theme.fg-muted;
                            vertical-alignment: center;
                        }
                    }
                }
            }

            Text {
                text: data.path;
                font-size: 12px;
                color: Theme.fg-muted;
                overflow: elide;
            }
        }

        HorizontalLayout {
            spacing: Theme.spacing-sm;
            alignment: end;
            GhostButton {
                width: 100px;
                text: "Редактировать";
                clicked => { root.edit(); }
            }
            GhostButton {
                width: 80px;
                text: "Удалить";
                destructive: true;
                clicked => { root.remove(); }
            }
        }
    }
}

export component StoragesPage inherits Rectangle {
    in property <[StorageRow]> storages;
    callback add-storage();
    callback edit-storage(string);
    callback delete-storage(string);

    background: Theme.bg;

    VerticalLayout {
        padding: Theme.spacing-xl;
        spacing: Theme.spacing-lg;

        HorizontalLayout {
            alignment: stretch;
            VerticalLayout {
                horizontal-stretch: 1;
                Text {
                    text: "Хранилища";
                    font-size: 22px;
                    font-weight: 700;
                    color: Theme.fg;
                }
                Text {
                    text: storages.length == 0
                        ? "Пока ничего не добавлено."
                        : ("Всего: " + storages.length);
                    font-size: 12px;
                    color: Theme.fg-muted;
                }
            }
            PrimaryButton {
                width: 160px;
                text: "+ Добавить";
                clicked => { root.add-storage(); }
            }
        }

        if storages.length == 0 : Rectangle {
            background: Theme.bg-elevated;
            border-radius: Theme.radius-md;
            border-width: 1px;
            border-color: Theme.border;
            height: 160px;
            VerticalLayout {
                padding: Theme.spacing-xl;
                alignment: center;
                spacing: Theme.spacing-sm;
                Text {
                    text: "💾";
                    font-size: 48px;
                    horizontal-alignment: center;
                }
                Text {
                    text: "Добавьте первое хранилище";
                    font-size: 16px;
                    font-weight: 600;
                    color: Theme.fg;
                    horizontal-alignment: center;
                }
                Text {
                    text: "Локальная папка или сетевой UNC-путь";
                    font-size: 13px;
                    color: Theme.fg-muted;
                    horizontal-alignment: center;
                }
            }
        }

        if storages.length > 0 : ScrollView {
            VerticalLayout {
                spacing: Theme.spacing-sm;
                for storage[i] in storages : StorageCard {
                    data: storage;
                    edit   => { root.edit-storage(storage.id); }
                    remove => { root.delete-storage(storage.id); }
                }
                Rectangle { height: Theme.spacing-md; }
            }
        }
    }
}
