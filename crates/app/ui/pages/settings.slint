import { ComboBox, SpinBox, CheckBox } from "std-widgets.slint";
import { Theme } from "../theme.slint";
import { PrimaryButton } from "../widgets/button.slint";
import { Card } from "../widgets/card.slint";

export component SettingsPage inherits Rectangle {
    in-out property <string> theme-value: "system";
    in-out property <int>    max-parallel: 2;
    in-out property <bool>   autostart-value: false;

    callback save-settings();

    background: Theme.bg;

    VerticalLayout {
        padding: Theme.spacing-xl;
        spacing: Theme.spacing-lg;

        Text {
            text: "Настройки";
            font-size: 22px;
            font-weight: 700;
            color: Theme.fg;
        }

        Card {
            VerticalLayout {
                padding: Theme.spacing-lg;
                spacing: Theme.spacing-md;

                Text {
                    text: "Внешний вид";
                    font-size: 14px;
                    font-weight: 600;
                    color: Theme.fg;
                }

                HorizontalLayout {
                    spacing: Theme.spacing-md;
                    alignment: start;
                    Text {
                        text: "Тема:";
                        font-size: 13px;
                        color: Theme.fg-muted;
                        vertical-alignment: center;
                    }
                    ComboBox {
                        width: 180px;
                        model: ["Системная", "Светлая", "Тёмная"];
                        current-index: root.theme-value == "light" ? 1
                                     : root.theme-value == "dark"  ? 2
                                     : 0;
                        selected(val) => {
                            root.theme-value = val == "Светлая" ? "light"
                                             : val == "Тёмная"  ? "dark"
                                             : "system";
                        }
                    }
                }

                HorizontalLayout {
                    spacing: Theme.spacing-md;
                    alignment: start;
                    Text {
                        text: "Параллельных заданий:";
                        font-size: 13px;
                        color: Theme.fg-muted;
                        vertical-alignment: center;
                    }
                    SpinBox {
                        width: 100px;
                        minimum: 1;
                        maximum: 16;
                        value <=> root.max-parallel;
                    }
                }

                HorizontalLayout {
                    spacing: Theme.spacing-md;
                    alignment: start;
                    CheckBox {
                        text: "Запускать при входе в Windows";
                        checked <=> root.autostart-value;
                    }
                }

                HorizontalLayout {
                    alignment: end;
                    PrimaryButton {
                        width: 120px;
                        text: "Сохранить";
                        clicked => { root.save-settings(); }
                    }
                }
            }
        }

        Rectangle { vertical-stretch: 1; }
    }
}
