import { Theme } from "../theme.slint";
import { Card, StatTile } from "../widgets/card.slint";

export struct RunRow {
    job-name: string,
    status: string,        // "ok" | "error" | "running" | "idle"
    status-label: string,
    when: string,          // относительное время
    duration: string,      // "1 мин 23 сек" или "—"
}

export component Dashboard inherits Rectangle {
    in property <int> total-jobs: 0;
    in property <int> ok-today: 0;
    in property <int> failed-today: 0;
    in property <string> next-run: "—";
    in property <[RunRow]> recent-runs: [];

    background: Theme.bg;

    VerticalLayout {
        padding: Theme.spacing-xl;
        spacing: Theme.spacing-lg;

        Text {
            text: "Обзор";
            font-size: 22px;
            font-weight: 700;
            color: Theme.fg;
        }

        HorizontalLayout {
            spacing: Theme.spacing-md;
            StatTile { label: "Активных заданий"; value: root.total-jobs; }
            StatTile { label: "Успешно за сегодня"; value: root.ok-today; accent: Theme.success; }
            StatTile { label: "Ошибок за сегодня"; value: root.failed-today; accent: Theme.danger; }
            StatTile { label: "Следующий запуск"; value: root.next-run; }
        }

        Card {
            VerticalLayout {
                padding: Theme.spacing-lg;
                spacing: Theme.spacing-sm;

                Text {
                    text: "Последние запуски";
                    font-size: 16px;
                    font-weight: 600;
                    color: Theme.fg;
                }

                if root.recent-runs.length == 0 : Text {
                    text: "Запусков пока не было.";
                    font-size: 13px;
                    color: Theme.fg-muted;
                }

                for run in root.recent-runs : HorizontalLayout {
                    spacing: Theme.spacing-md;
                    padding-top: 4px;
                    padding-bottom: 4px;

                    property <color> row-color:
                        run.status == "ok"      ? Theme.success
                      : run.status == "error"   ? Theme.danger
                      : run.status == "running" ? Theme.accent
                      :                           Theme.fg-muted;

                    Rectangle {
                        width: 8px;
                        height: 8px;
                        border-radius: 4px;
                        background: row-color;
                        y: (parent.height - self.height) / 2;
                    }
                    Text {
                        text: run.job-name;
                        font-size: 13px;
                        color: Theme.fg;
                        horizontal-stretch: 1;
                        overflow: elide;
                    }
                    Text {
                        text: run.status-label;
                        font-size: 12px;
                        color: row-color;
                        width: 80px;
                        horizontal-alignment: right;
                    }
                    Text {
                        text: run.duration;
                        font-size: 12px;
                        color: Theme.fg-muted;
                        width: 80px;
                        horizontal-alignment: right;
                    }
                    Text {
                        text: run.when;
                        font-size: 12px;
                        color: Theme.fg-muted;
                        width: 90px;
                        horizontal-alignment: right;
                    }
                }
            }
        }

        Rectangle { vertical-stretch: 1; }
    }
}
