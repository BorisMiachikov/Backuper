import { Palette, ScrollView } from "std-widgets.slint";
import { Theme } from "../theme.slint";
import { Card } from "../widgets/card.slint";
import { PrimaryButton, GhostButton } from "../widgets/button.slint";

export struct SourceRow {
    id: string,
    name: string,
    kind: string,
    path: string,
    description: string,
    tags: string,
    enabled: bool,
}

component SourceCard inherits Rectangle {
    in property <SourceRow> data;
    callback edit;
    callback remove;
    callback run-now;

    background: Theme.bg-elevated;
    border-radius: Theme.radius-md;
    border-width: 1px;
    border-color: Theme.border;
    height: 96px;

    HorizontalLayout {
        padding: Theme.spacing-lg;
        spacing: Theme.spacing-lg;
        alignment: stretch;

        // Левая часть — название + путь + теги
        VerticalLayout {
            horizontal-stretch: 1;
            spacing: 4px;
            alignment: center;

            HorizontalLayout {
                spacing: Theme.spacing-sm;
                Text {
                    text: data.name;
                    font-size: 15px;
                    font-weight: 600;
                    color: Theme.fg;
                }
                Rectangle {
                    background: Theme.accent.with-alpha(0.15);
                    border-radius: 4px;
                    height: 18px;
                    HorizontalLayout {
                        padding-left: 6px;
                        padding-right: 6px;
                        Text {
                            text: data.kind;
                            font-size: 11px;
                            color: Theme.accent;
                            vertical-alignment: center;
                        }
                    }
                }
                if !data.enabled : Rectangle {
                    background: Theme.fg-muted.with-alpha(0.15);
                    border-radius: 4px;
                    height: 18px;
                    HorizontalLayout {
                        padding-left: 6px;
                        padding-right: 6px;
                        Text {
                            text: "выключен";
                            font-size: 11px;
                            color: Theme.fg-muted;
                            vertical-alignment: center;
                        }
                    }
                }
            }

            Text {
                text: data.path;
                font-size: 12px;
                color: Theme.fg-muted;
                overflow: elide;
            }

            if data.tags != "" : Text {
                text: "🏷  " + data.tags;
                font-size: 11px;
                color: Theme.fg-muted;
            }
        }

        // Правая часть — кнопки
        HorizontalLayout {
            spacing: Theme.spacing-sm;
            alignment: end;
            GhostButton {
                width: 100px;
                text: "Редактировать";
                clicked => { root.edit(); }
            }
            GhostButton {
                width: 80px;
                text: "Удалить";
                destructive: true;
                clicked => { root.remove(); }
            }
        }
    }
}

export component SourcesPage inherits Rectangle {
    in property <[SourceRow]> sources;
    callback add-source();
    callback edit-source(string);
    callback delete-source(string);

    background: Theme.bg;

    VerticalLayout {
        padding: Theme.spacing-xl;
        spacing: Theme.spacing-lg;

        HorizontalLayout {
            alignment: stretch;
            VerticalLayout {
                horizontal-stretch: 1;
                Text {
                    text: "Источники";
                    font-size: 22px;
                    font-weight: 700;
                    color: Theme.fg;
                }
                Text {
                    text: sources.length == 0 ? "Пока ничего не добавлено." : (
                        "Всего: " + sources.length
                    );
                    font-size: 12px;
                    color: Theme.fg-muted;
                }
            }
            PrimaryButton {
                width: 160px;
                text: "+ Добавить";
                clicked => { root.add-source(); }
            }
        }

        if sources.length == 0 : Card {
            VerticalLayout {
                padding: Theme.spacing-xl;
                alignment: center;
                spacing: Theme.spacing-sm;
                Text {
                    text: "📂";
                    font-size: 48px;
                    horizontal-alignment: center;
                }
                Text {
                    text: "Добавьте первый источник";
                    font-size: 16px;
                    font-weight: 600;
                    color: Theme.fg;
                    horizontal-alignment: center;
                }
                Text {
                    text: "Базу 1С, папку или набор файлов";
                    font-size: 13px;
                    color: Theme.fg-muted;
                    horizontal-alignment: center;
                }
            }
        }

        if sources.length > 0 : ScrollView {
            VerticalLayout {
                spacing: Theme.spacing-sm;
                for source[i] in sources : SourceCard {
                    data: source;
                    edit => { root.edit-source(source.id); }
                    remove => { root.delete-source(source.id); }
                }
                Rectangle { height: Theme.spacing-md; } // нижний отступ
            }
        }
    }
}
