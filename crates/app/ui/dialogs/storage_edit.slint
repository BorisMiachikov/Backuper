import { ComboBox, LineEdit, CheckBox } from "std-widgets.slint";
import { Theme } from "../theme.slint";
import { PrimaryButton, GhostButton } from "../widgets/button.slint";

export component StorageEditDialog inherits Rectangle {
    in-out property <bool>   open: false;
    in-out property <string> dialog-id: "";        // "" = новое, uuid = редактирование
    in-out property <string> name-value;
    in-out property <string> kind-value: "local";  // "local" | "smb"
    in-out property <string> path-value;           // root (local) или unc (smb)
    in-out property <bool>   enabled-value: true;

    callback save();
    callback cancel();
    callback browse-path();

    visible: root.open;
    width: 100%;
    height: 100%;
    background: #00000088;

    TouchArea {}

    Rectangle {
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        width: min(parent.width - 64px, 520px);
        height: 360px;
        background: Theme.bg-elevated;
        border-radius: Theme.radius-md;
        border-width: 1px;
        border-color: Theme.border;

        VerticalLayout {
            padding: Theme.spacing-xl;
            spacing: Theme.spacing-md;

            Text {
                text: root.dialog-id == "" ? "Новое хранилище" : "Редактировать хранилище";
                font-size: 18px;
                font-weight: 700;
                color: Theme.fg;
            }

            VerticalLayout {
                spacing: 4px;
                Text { text: "Название"; font-size: 12px; color: Theme.fg-muted; }
                LineEdit {
                    text <=> root.name-value;
                    placeholder-text: "например, «Бэкапы на D:»";
                }
            }

            VerticalLayout {
                spacing: 4px;
                Text { text: "Тип"; font-size: 12px; color: Theme.fg-muted; }
                ComboBox {
                    model: ["Локальная папка", "Сетевой UNC-путь"];
                    current-index: root.kind-value == "smb" ? 1 : 0;
                    selected(val) => {
                        root.kind-value = val == "Сетевой UNC-путь" ? "smb" : "local";
                    }
                }
            }

            VerticalLayout {
                spacing: 4px;
                Text {
                    text: root.kind-value == "smb" ? "UNC-путь (\\\\сервер\\папка)" : "Путь к папке";
                    font-size: 12px;
                    color: Theme.fg-muted;
                }
                HorizontalLayout {
                    spacing: Theme.spacing-sm;
                    LineEdit {
                        horizontal-stretch: 1;
                        text <=> root.path-value;
                        placeholder-text: root.kind-value == "smb"
                            ? "\\\\server\\backups"
                            : "D:\\Backups";
                    }
                    if root.kind-value == "local" : GhostButton {
                        width: 80px;
                        text: "Browse…";
                        clicked => { root.browse-path(); }
                    }
                }
            }

            HorizontalLayout {
                spacing: Theme.spacing-sm;
                alignment: start;
                CheckBox {
                    text: "Включено";
                    checked <=> root.enabled-value;
                }
            }

            Rectangle { vertical-stretch: 1; }

            HorizontalLayout {
                alignment: end;
                spacing: Theme.spacing-sm;
                GhostButton {
                    width: 90px;
                    text: "Отмена";
                    clicked => { root.cancel(); }
                }
                PrimaryButton {
                    width: 120px;
                    text: "Сохранить";
                    enabled: root.name-value != "" && root.path-value != "";
                    clicked => { root.save(); }
                }
            }
        }
    }
}
