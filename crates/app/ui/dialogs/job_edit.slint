import { ComboBox, LineEdit, CheckBox } from "std-widgets.slint";
import { Theme } from "../theme.slint";
import { PrimaryButton, GhostButton } from "../widgets/button.slint";

export component JobEditDialog inherits Rectangle {
    in-out property <bool> open: false;
    in-out property <string> name-value;
    in-out property <string> source-value;       // имя источника, выбранное в ComboBox
    in-out property <bool>   enabled-value: true;
    in property <[string]> source-options: [];

    callback save();
    callback cancel();

    visible: root.open;
    width: 100%;
    height: 100%;
    background: #00000088;

    TouchArea {}

    Rectangle {
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        width: min(parent.width - 64px, 520px);
        height: 360px;
        background: Theme.bg-elevated;
        border-radius: Theme.radius-md;
        border-width: 1px;
        border-color: Theme.border;

        VerticalLayout {
            padding: Theme.spacing-xl;
            spacing: Theme.spacing-md;

            Text {
                text: "Новое задание";
                font-size: 18px;
                font-weight: 700;
                color: Theme.fg;
            }

            VerticalLayout {
                spacing: 4px;
                Text { text: "Название"; font-size: 12px; color: Theme.fg-muted; }
                LineEdit {
                    text <=> root.name-value;
                    placeholder-text: "например, «Бэкап бухгалтерии»";
                }
            }

            VerticalLayout {
                spacing: 4px;
                Text { text: "Источник"; font-size: 12px; color: Theme.fg-muted; }
                if root.source-options.length == 0 : Text {
                    text: "Сначала добавьте хотя бы один источник";
                    color: Theme.warning;
                    font-size: 12px;
                }
                if root.source-options.length > 0 : ComboBox {
                    model: root.source-options;
                    current-value <=> root.source-value;
                }
            }

            HorizontalLayout {
                spacing: Theme.spacing-sm;
                alignment: start;
                CheckBox {
                    text: "Включено";
                    checked <=> root.enabled-value;
                }
            }

            Text {
                text: "Архивы сохраняются в %LOCALAPPDATA%\\Backuper\\archives\\";
                font-size: 11px;
                color: Theme.fg-muted;
            }

            Rectangle { vertical-stretch: 1; }

            HorizontalLayout {
                alignment: end;
                spacing: Theme.spacing-sm;
                GhostButton {
                    width: 90px;
                    text: "Отмена";
                    clicked => { root.cancel(); }
                }
                PrimaryButton {
                    width: 120px;
                    text: "Сохранить";
                    enabled: root.name-value != "" && root.source-value != "";
                    clicked => { root.save(); }
                }
            }
        }
    }
}
